{
  "name": "keisetsu-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "test:spec": "jest --runInBand",
    "test:e2e": "playwright test",
    "test": "npm run test:spec && npm run test:e2e",
    "typecheck": "tsc --noEmit",
    "build:ci": "npm run build:ci:ios && npm run build:ci:android",
    "build:ci:ios": "CI=1 expo export --platform ios --output-dir dist/ios",
    "build:ci:android": "CI=1 expo export --platform android --output-dir dist/android"
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-localization": "^55.0.9",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "eslint": "^8.57.1",
    "eslint-config-universe": "^13.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "playwright": "^1.55.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
